rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── students ──
    // Synced by Cloud Function from NPF. Students can read their own doc
    // by doc ID (= application_no). No client writes.
    match /students/{applicationNo} {
      allow read: if true;   // No Auth yet — tighten to own-record when Auth added
      allow write: if false;  // Only Cloud Function writes
    }

    // ── tests ──
    // Published test configs. Read-only for everyone.
    match /tests/{testId} {
      allow read: if true;
      allow write: if false;
    }

    // ── questions ──
    // SECURED: clients can still read questions (need text + options),
    // but correctAnswerIndex is stripped by QuestionService before it
    // reaches the app. Scoring happens in the scoreSubmission Cloud
    // Function which reads server-side.
    match /questions/{questionId} {
      allow read: if true;    // Text + options needed client-side
      allow write: if false;
    }

    // ── results ──
    // Created by the student app on submission. Admin dashboard reads all.
    // No client-side updates or deletes — results are immutable once written.
    match /results/{resultId} {
      allow read: if true;    // Admin dashboard reads all results
      allow create: if true;  // Student app writes result on submission
      allow update, delete: if false;
    }

    // ── attempts ──
    // Created by client at test start (transactional lock).
    // Updated only by scoreSubmission Cloud Function (status flip to completed).
    match /attempts/{applicationNo} {
      allow read: if true;
      allow create: if true;   // Transactional lock at test start
      allow update: if false;  // Only Cloud Function flips to completed
      allow delete: if false;
    }

    // ── otps ──
    // Written and read ONLY by Cloud Functions. Fully closed to clients.
    match /otps/{applicationNo} {
      allow read, write: if false;
    }

    // ── app_logs ──
    // Written by the client-side AppLogger for structured error/info logs.
    // Read access is restricted to authenticated admins via Firebase Console or UI.
    match /app_logs/{logId} {
      allow create: if true;   // Client writes log entries
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow update, delete: if false;
    }

    // ── notifications ──
    // Written by Cloud Function. Admin reads history.
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Catch-all: deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
