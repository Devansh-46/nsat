rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // ── students ─────────────────────────────────────────────────────
    // Read: anyone (fee-gate login step, no auth needed)
    // Write: Cloud Functions only (syncStudents)
    match /students/{applicationNo} {
      allow read: if true;
      allow write: if false;
    }

    // ── tests ────────────────────────────────────────────────────────
    // Read: anyone (shown after OTP verification)
    // Write: admin only
    match /tests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── questions ────────────────────────────────────────────────────
    // Read: anyone (fetched after OTP verification)
    // Write: admin only
    // NOTE: correctAnswerIndex is in these docs. The client-side
    // QuestionService strips it when _stripAnswers = true.
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── attempts ─────────────────────────────────────────────────────
    // Read: anyone (checked by app logic)
    // Create: anyone (OTP verification is the gate, status must be in_progress)
    // Update: admin only (Cloud Function marks completed via admin SDK)
    match /attempts/{applicationNo} {
      allow read: if true;
      allow create: if true
                    && request.resource.data.status == 'in_progress';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── results ──────────────────────────────────────────────────────
    // Read: admin only (students never read results from Firestore;
    //       scores are returned via Cloud Function response)
    // Write: Cloud Functions only (scoreSubmission)
    match /results/{resultId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── otps ─────────────────────────────────────────────────────────
    // Cloud Functions only; never accessible by clients
    match /otps/{applicationNo} {
      allow read: if false;
      allow write: if false;
    }

    // ── notifications ────────────────────────────────────────────────
    // Read: authenticated users
    // Write: admin only
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── admins ─────────────────────────────────────────────────────────
    // Read: admin only
    // Write: Cloud Functions only (superadmin check is server-side)
    match /admins/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── superadmins ────────────────────────────────────────────────────
    // Read: admin only (for listing in UI)
    // Write: Cloud Functions only (promoteSuperadmin / demoteSuperadmin)
    match /superadmins/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── app_logs ─────────────────────────────────────────────────────
    // Write: anyone (logging works pre-auth too)
    // Read: admin only
    match /app_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    // ── _meta ────────────────────────────────────────────────────────
    // Internal sync metadata; admin-read only; CF writes via admin SDK
    match /_meta/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
