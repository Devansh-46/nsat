rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(applicationNo) {
      return isAuthenticated() && request.auth.token.application_no == applicationNo;
    }

    // ── students ─────────────────────────────────────────────────────
    // Read: allowed without auth for the fee-gate login step; write: never from client
    match /students/{applicationNo} {
      allow read: if true;
      allow write: if false; // only Cloud Functions (syncStudents) write here
    }

    // ── tests ────────────────────────────────────────────────────────
    // Published tests readable by authenticated students; admins can write
    match /tests/{testId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── questions ────────────────────────────────────────────────────
    // Readable by authenticated students; scoring is server-side.
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── attempts ─────────────────────────────────────────────────────
    // Read: authenticated users (anonymous sign-in after OTP is the gate)
    // Create: authenticated, must match own applicationNo from doc ID
    // Update: admin only (Cloud Function marks completed)
    match /attempts/{applicationNo} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.status == 'in_progress';
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── results ──────────────────────────────────────────────────────
    // Create: Cloud Function only (scoreSubmission writes results)
    // Read: admin only; students do NOT read results directly (shown via CF return value)
    match /results/{resultId} {
      allow read: if isAdmin();
      allow create: if false; // Cloud Function writes results server-side
      allow update: if false;
      allow delete: if false;
    }

    // ── otps ─────────────────────────────────────────────────────────
    // Written and deleted by Cloud Functions only; never readable by clients
    match /otps/{applicationNo} {
      allow read: if false;
      allow write: if false;
    }

    // ── notifications ────────────────────────────────────────────────
    // Students read their own notifications; admins can read/write
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // sendNotification CF also writes here via admin SDK
    }

    // ── admins ─────────────────────────────────────────────────────────
    // Regular admin list. Superadmins (from .env) manage this collection.
    // Read: any authenticated admin. Write: superadmins only (enforced by CF).
    match /admins/{email} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only (superadmin check is server-side)
    }

    // ── app_logs ─────────────────────────────────────────────────────
    // Write from authenticated app; read by admins only
    match /app_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── _meta ────────────────────────────────────────────────────────
    // Internal sync metadata; admin-read only; CF writes via admin SDK
    match /_meta/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
