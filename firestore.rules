rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // students — synced NPF data. App reads; only sync function writes.
    // TEMPORARY: read open for development. Tighten once auth is built.
    match /students/{niuId} {
      allow read: if true;
      allow write: if false;
    }

    // tests — readable by app, not writable by client.
    match /tests/{testId} {
      allow read: if true;
      allow write: if false;
    }

    // questions — client cannot read directly (holds correct answers).
    match /questions/{questionId} {
      allow read: if false;
      allow write: if false;
    }

    // results — a signed-in student may create; never edit/delete.
    match /results/{resultId} {
      allow read: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    // attempts — the one-attempt lock. Create only; never update/delete.
    match /attempts/{niuId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    // otps — fully closed to clients. Cloud Functions only.
    match /otps/{niuId} {
      allow read: if false;
      allow write: if false;
    }

    // deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
